generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  role         String   // homeowner | provider | admin | suspended
  phone        String?
  createdAt    DateTime @default(now()) @map("created_at")

  providerProfile     ProviderProfile?
  jobsAsHomeowner     Job[]            @relation("HomeownerJobs")
  bids                Bid[]
  sentMessages        Message[]        @relation("SentMessages")
  receivedMessages    Message[]        @relation("ReceivedMessages")
  homeownerConvos     Conversation[]   @relation("HomeownerConversations")
  providerConvos      Conversation[]   @relation("ProviderConversations")
  notifications       Notification[]
  jobBroadcasts       JobBroadcast[]
  uploadedDocuments   UploadedDocument[]
  verificationRequests VerificationRequest[]
  reviewsGiven        Review[]         @relation("ReviewerReviews")
  reviewsReceived     Review[]         @relation("ProviderReviews")

  @@map("users")
}

model ProviderProfile {
  userId              Int      @id @map("user_id")
  bio                 String   @default("")
  categories          String[]
  hourlyRate          Decimal  @default(0) @map("hourly_rate") @db.Decimal(10, 2)
  yearsExperience     Int      @default(0) @map("years_experience")
  isAvailable         Boolean  @default(true) @map("is_available")
  profilePictureUrl   String?  @map("profile_picture_url")
  idDocumentUrl       String?  @map("id_document_url")
  licenseDocumentUrl  String?  @map("license_document_url")
  verificationStatus  String   @default("unverified") @map("verification_status")
  verificationNotes   String   @default("") @map("verification_notes")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("provider_profiles")
}

model Job {
  id                   Int       @id @default(autoincrement())
  homeownerId          Int       @map("homeowner_id")
  category             String
  title                String
  description          String
  address              String
  preferredDate        String?   @map("preferred_date")
  preferredTime        String?   @map("preferred_time")
  estimatedHours       Decimal?  @map("estimated_hours") @db.Decimal(6, 2)
  estimatedDays        Decimal?  @map("estimated_days") @db.Decimal(6, 2)
  additionalNotes      String    @default("") @map("additional_notes")
  budget               Decimal?  @db.Decimal(10, 2)
  aiSuggestedMin       Decimal?  @map("ai_suggested_min") @db.Decimal(10, 2)
  aiSuggestedMax       Decimal?  @map("ai_suggested_max") @db.Decimal(10, 2)
  aiReasoning          String?   @map("ai_reasoning")
  status               String    @default("open")
  acceptedBidId        Int?      @map("accepted_bid_id")
  completionRequestedAt DateTime? @map("completion_requested_at")
  completedAt          DateTime? @map("completed_at")
  createdAt            DateTime  @default(now()) @map("created_at")

  homeowner   User        @relation("HomeownerJobs", fields: [homeownerId], references: [id], onDelete: Cascade)
  photos      JobPhoto[]
  bids        Bid[]
  messages    Message[]
  conversations Conversation[]
  payment     Payment?
  broadcasts  JobBroadcast[]
  review      Review[]

  @@map("jobs")
}

model JobPhoto {
  id           Int      @id @default(autoincrement())
  jobId        Int      @map("job_id")
  originalName String   @map("original_name")
  mimeType     String   @map("mime_type")
  fileUrl      String   @map("file_url")
  sizeBytes    Int      @default(0) @map("size_bytes")
  uploadedAt   DateTime @default(now()) @map("uploaded_at")

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("job_photos")
}

model Bid {
  id            Int      @id @default(autoincrement())
  jobId         Int      @map("job_id")
  providerId    Int      @map("provider_id")
  hourlyRate    Decimal  @map("hourly_rate") @db.Decimal(10, 2)
  hoursEstimate Decimal  @map("hours_estimate") @db.Decimal(6, 2)
  equipmentCost Decimal  @default(0) @map("equipment_cost") @db.Decimal(10, 2)
  total         Decimal  @db.Decimal(10, 2)
  message       String   @default("")
  status        String   @default("pending")
  createdAt     DateTime @default(now()) @map("created_at")

  job      Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  provider User @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([jobId, providerId])
  @@map("bids")
}

model Conversation {
  id          Int      @id @default(autoincrement())
  jobId       Int      @map("job_id")
  homeownerId Int      @map("homeowner_id")
  providerId  Int      @map("provider_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @map("updated_at")

  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  homeowner User     @relation("HomeownerConversations", fields: [homeownerId], references: [id], onDelete: Cascade)
  provider  User     @relation("ProviderConversations", fields: [providerId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@unique([jobId, providerId])
  @@map("conversations")
}

model Message {
  id              Int       @id @default(autoincrement())
  jobId           Int       @map("job_id")
  conversationId  Int?      @map("conversation_id")
  senderId        Int       @map("sender_id")
  receiverId      Int?      @map("receiver_id")
  body            String
  attachmentUrl   String?   @map("attachment_url")
  attachmentName  String?   @map("attachment_name")
  attachmentType  String?   @map("attachment_type")
  attachmentSize  Int?      @map("attachment_size")
  readAt          DateTime? @map("read_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  job          Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id])
  sender       User          @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver     User?         @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: SetNull)

  @@map("messages")
}

model VerificationRequest {
  id                   Int       @id @default(autoincrement())
  providerId           Int       @map("provider_id")
  status               String    @default("pending")
  fullName             String    @map("full_name")
  documentType         String    @map("document_type")
  documentDescription  String    @map("document_description")
  idDocumentUrl        String    @map("id_document_url")
  licenseDocumentUrl   String?   @map("license_document_url")
  adminNotes           String    @default("") @map("admin_notes")
  submittedAt          DateTime  @default(now()) @map("submitted_at")
  reviewedAt           DateTime? @map("reviewed_at")

  provider User @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("verification_requests")
}

model Review {
  id         Int      @id @default(autoincrement())
  jobId      Int      @map("job_id")
  reviewerId Int      @map("reviewer_id")
  providerId Int      @map("provider_id")
  rating     Int
  comment    String   @default("")
  createdAt  DateTime @default(now()) @map("created_at")

  job      Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  reviewer User @relation("ReviewerReviews", fields: [reviewerId], references: [id], onDelete: Cascade)
  provider User @relation("ProviderReviews", fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([jobId, reviewerId])
  @@map("reviews")
}

model Payment {
  id        Int      @id @default(autoincrement())
  jobId     Int      @unique @map("job_id")
  amount    Decimal  @db.Decimal(10, 2)
  status    String   @default("pending")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  title     String
  body      String
  link      String?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model JobBroadcast {
  id          Int       @id @default(autoincrement())
  jobId       Int       @map("job_id")
  providerId  Int       @map("provider_id")
  status      String    @default("pending")
  createdAt   DateTime  @default(now()) @map("created_at")
  respondedAt DateTime? @map("responded_at")

  job      Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  provider User @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([jobId, providerId])
  @@map("job_broadcasts")
}

model UploadedDocument {
  id           Int      @id @default(autoincrement())
  providerId   Int      @map("provider_id")
  documentType String   @map("document_type")
  originalName String   @map("original_name")
  storedName   String   @default("") @map("stored_name")
  mimeType     String   @map("mime_type")
  fileUrl      String   @map("file_url")
  sizeBytes    Int      @default(0) @map("size_bytes")
  uploadedAt   DateTime @default(now()) @map("uploaded_at")

  provider User @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("uploaded_documents")
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String   @default("")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("categories")
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @default(now()) @map("updated_at")

  @@map("settings")
}
